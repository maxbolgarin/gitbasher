---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

const base = (import.meta.env.BASE_URL ?? '/').replace(/\/$/, '');
---
<Base
  title="404 — Page not found · Gitbasher"
  description="Page not found. Head back to the gitbasher home page."
  path="/404"
>
  <Nav slot="header" />

  <section class="not-found">
    <div class="container">
      <div class="terminal" style="max-width:560px;margin:0 auto;">
        <div class="terminal-header">
          <span class="dot red"></span>
          <span class="dot yellow"></span>
          <span class="dot green"></span>
          <span class="title">~/gitbasher</span>
        </div>
        <div class="terminal-body">
          <pre><code><span class="prompt-arrow">❯</span> <span class="cmd">gitb find</span> <span class="flag">"this-page"</span>
<span class="err">✗ Not found.</span>
<span class="tip">💡</span> Try the home page or open an issue if you expected something here.</code></pre>
        </div>
      </div>

      <div class="actions">
        <a class="btn btn-primary" href={`${base}/`}>← Back to home</a>
        <a class="btn" href="https://github.com/maxbolgarin/gitbasher/issues" rel="noopener">Open an issue</a>
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</Base>

<style>
  .not-found {
    padding: clamp(3rem, 8vw, 6rem) 0;
    text-align: center;
  }

  .actions {
    display: flex;
    gap: 0.7rem;
    justify-content: center;
    flex-wrap: wrap;
    margin-top: 1.6rem;
  }
</style>
