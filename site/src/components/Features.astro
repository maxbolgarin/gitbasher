---
const features = [
  {
    icon: '✱',
    title: 'Conventional commits, free',
    body: 'Type/scope/summary picker, ticket prefixes, multiline editor mode, atomic split, fixup, amend, revert — all without remembering a single flag.',
    cmd: 'gitb commit',
  },
  {
    icon: '✦',
    title: 'AI commit messages',
    body: 'Generate clear conventional messages from your staged diff. OpenAI, OpenRouter (Gemini/Claude/GPT/…) or fully local Ollama. Switch providers with one command.',
    cmd: 'gitb commit ai',
  },
  {
    icon: '↻',
    title: 'Smart sync',
    body: 'Safe push (with force-with-lease), smart pull (rebase / merge / ff), one-shot rebase-on-main. Conflicts detected up front, not mid-flight.',
    cmd: 'gitb sync push',
  },
  {
    icon: '⏪',
    title: 'Undo everything',
    body: 'Roll back commit, amend, merge, rebase, stash — interactively with a preview. Mistakes are recoverable; that\'s the whole point.',
    cmd: 'gitb undo',
  },
  {
    icon: '⎘',
    title: 'WIP across machines',
    body: 'Stash + push backup to origin/wip/<branch> in one command. Pull it on another machine, restore with a single command, auto-clean.',
    cmd: 'gitb wip up',
  },
  {
    icon: '⌬',
    title: 'Worktrees made simple',
    body: 'Add, list, remove, move, lock, prune. Spin up a new branch in a fresh directory and switch contexts without stashing.',
    cmd: 'gitb worktree add',
  },
  {
    icon: '⚲',
    title: 'AI-driven squash',
    body: 'Fold a messy feature branch into clean, changelog-ready commits. Gitbasher proposes the squash plan; you confirm.',
    cmd: 'gitb squash',
  },
  {
    icon: '⚙',
    title: 'Hooks & config',
    body: 'List / create / edit / toggle / test every git hook from templates. User, scopes, AI provider, ticket prefix — all editable from one menu.',
    cmd: 'gitb hook',
  },
];
---
<section id="features" class="section features">
  <div class="container">
    <header class="section-title">
      <small>Features</small>
      <h2>Whole workflows, not just commands</h2>
      <p>
        24 top-level commands cover the day-to-day moves that take five
        keystrokes in <code>git</code> and a glance at the man page. With gitbasher,
        they take three words.
      </p>
    </header>

    <ul class="feature-grid">
      {features.map((f) => (
        <li class="feature-card">
          <div class="feature-icon" aria-hidden="true">{f.icon}</div>
          <h3>{f.title}</h3>
          <p>{f.body}</p>
          <code class="feature-cmd">{f.cmd}</code>
        </li>
      ))}
    </ul>
  </div>
</section>

<style>
  .feature-grid {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 1rem;
  }

  .feature-card {
    background: var(--bg-elev);
    border: 1px solid var(--border-soft);
    border-radius: var(--radius-lg);
    padding: 1.4rem;
    transition: border-color 0.15s ease, transform 0.15s ease;
  }

  .feature-card:hover {
    border-color: var(--border);
    transform: translateY(-2px);
  }

  .feature-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 38px;
    height: 38px;
    border-radius: 8px;
    background: rgba(126, 231, 135, 0.1);
    color: var(--green);
    font-size: 1.3rem;
    margin-bottom: 0.8rem;
  }

  .feature-card h3 {
    margin: 0 0 0.4rem;
    color: var(--fg);
  }

  .feature-card p {
    color: var(--fg-muted);
    font-size: 0.95rem;
    margin: 0 0 0.9rem;
  }

  .feature-cmd {
    display: inline-block;
    color: var(--green);
    background: var(--bg-elev-2);
    border: 1px solid var(--border-soft);
    border-radius: 4px;
    padding: 0.15em 0.5em;
    font-size: 0.85rem;
  }
</style>
