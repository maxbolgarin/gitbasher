            echo -e "  • Provider: ${provider}" >&2
            echo -e "${YELLOW}Direct connection troubleshooting:${ENDCOLOR}" >&2
            echo -e "  • Test connection: ${BOLD}curl --connect-timeout 10 ${probe_host}${ENDCOLOR}" >&2
