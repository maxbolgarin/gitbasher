---
import '../styles/global.css';

export interface Props {
  title?: string;
  description?: string;
  /** Path relative to base, e.g. "/" or "/faq" */
  path?: string;
  /** Hide utility pages such as 404 from search results. */
  noindex?: boolean;
  /** Additional JSON-LD objects to inject. Each is stringified into a <script> tag. */
  jsonLd?: Record<string, unknown>[];
}

const {
  title = 'Gitbasher: Git CLI wrapper for AI commit messages and safe workflows',
  description = 'Gitbasher is an open-source git CLI wrapper for conventional commits, AI commit messages with OpenAI, OpenRouter, or local Ollama, smart sync, branch cleanup, WIP backup, and safe undo workflows.',
  path = '/',
  noindex = false,
  jsonLd = [],
} = Astro.props;

const siteOrigin = Astro.site?.toString().replace(/\/$/, '') ?? 'https://maxbolgarin.github.io';
const base = (import.meta.env.BASE_URL ?? '/').replace(/\/$/, '');
const normalizedPath = path === '/' ? '/' : `${path.replace(/\/$/, '')}/`;
const canonical = `${siteOrigin}${base}${normalizedPath}`;
const ogImage = `${siteOrigin}${base}/og-image.jpg`;
const siteUrl = `${siteOrigin}${base}/`;
const siteName = 'Gitbasher';
const robotsContent = noindex
  ? 'noindex, follow'
  : 'index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1';

const softwareJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: siteName,
  alternateName: 'gitb',
  description,
  applicationCategory: 'DeveloperApplication',
  operatingSystem: 'Linux, macOS, Windows (WSL)',
  url: siteUrl,
  downloadUrl: 'https://raw.githubusercontent.com/maxbolgarin/gitbasher/main/install.sh',
  softwareVersion: '4.0.0',
  license: 'https://github.com/maxbolgarin/gitbasher/blob/main/LICENSE',
  codeRepository: 'https://github.com/maxbolgarin/gitbasher',
  programmingLanguage: 'Bash',
  featureList: [
    'Conventional commit prompts',
    'AI commit message generation',
    'Local Ollama support',
    'Safe undo workflows',
    'Branch, worktree, and WIP helpers',
  ],
  offers: {
    '@type': 'Offer',
    price: '0',
    priceCurrency: 'USD',
  },
  author: {
    '@type': 'Person',
    name: 'Max Bolgarin',
    url: 'https://github.com/maxbolgarin',
  },
  image: ogImage,
};

const websiteJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: siteName,
  alternateName: 'gitb',
  description,
  url: siteUrl,
  inLanguage: 'en',
  publisher: {
    '@type': 'Person',
    name: 'Max Bolgarin',
    url: 'https://github.com/maxbolgarin',
  },
};

const breadcrumbJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    {
      '@type': 'ListItem',
      position: 1,
      name: 'Gitbasher',
      item: siteUrl,
    },
  ],
};

const allJsonLd = [softwareJsonLd, websiteJsonLd, breadcrumbJsonLd, ...jsonLd];
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="author" content="Max Bolgarin" />
    <meta name="robots" content={robotsContent} />
    <meta name="googlebot" content={robotsContent} />
    <meta name="referrer" content="strict-origin-when-cross-origin" />
    <meta name="format-detection" content="telephone=no" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <meta name="theme-color" content="#0d1117" />
    <meta name="color-scheme" content="dark" />

    <link rel="icon" type="image/svg+xml" href={`${base}/favicon.svg`} />
    <link rel="manifest" href={`${base}/manifest.webmanifest`} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:locale" content="en_US" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:secure_url" content={ogImage} />
    <meta property="og:image:type" content="image/jpeg" />
    <meta property="og:image:width" content="875" />
    <meta property="og:image:height" content="492" />
    <meta property="og:image:alt" content="Gitbasher — friendly git wrapper" />

    <!-- Twitter card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:image:alt" content="Gitbasher terminal UI preview and install command" />

    <!-- Keywords (low SEO weight today, harmless to include) -->
    <meta
      name="keywords"
      content="gitbasher, gitb, git CLI wrapper, git wrapper, AI commit messages, conventional commits, ollama git, openrouter git, openai git commits, git workflow automation, bash git, open source git tool, MIT, git productivity"
    />

    <!-- Structured data -->
    {allJsonLd.map((data) => (
      <script type="application/ld+json" set:html={JSON.stringify(data)} />
    ))}

    <link rel="sitemap" href={`${base}/sitemap-index.xml`} />
  </head>
  <body>
    <a href="#main" class="sr-only">Skip to main content</a>
    <slot name="header" />
    <main id="main">
      <slot />
    </main>
    <slot name="footer" />
  </body>
</html>
