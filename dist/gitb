    git_status
    echo
    local stash_output
    stash_output=$(git stash push --include-untracked --message "wip-transfer: ${current_branch}" 2>&1)
    if [ $? -ne 0 ]; then
        echo -e "${RED}Cannot stash changes for transfer:${ENDCOLOR}"
        echo "$stash_output"
        exit 1
    fi
