{
    "name": "gitbasher",
    "version": "3.10.2",
    "description": "Simple bash utility that makes git easy to use",
    "keywords": [
        "git",
        "bash",
        "cli",
        "version-control"
    ],
    "author": "maxbolgarin",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/maxbolgarin/gitbasher.git"
    },
    "homepage": "https://github.com/maxbolgarin/gitbasher#readme",
    "bin": {
        "gitb": "dist/gitb"
    },
    "files": [
        "dist/gitb",
        "README.md",
        "LICENSE"
    ],
    "engines": {
        "node": ">=14.0.0"
    },
    "devDependencies": {
        "semantic-release": "latest",
        "@semantic-release/commit-analyzer": "latest",
        "@semantic-release/release-notes-generator": "latest",
        "@semantic-release/exec": "latest",
        "@semantic-release/github": "latest",
        "@semantic-release/npm": "latest",
        "@semantic-release/git": "latest",
        "conventional-changelog-conventionalcommits": "latest"
    }
}
