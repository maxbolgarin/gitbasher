---
const rows = [
  {
    task: 'Start a feature off updated main',
    before: 'git fetch && git checkout main && git pull --ff-only && git checkout -b feat/x',
    after: 'gitb branch newd',
  },
  {
    task: 'Conventional commit + push',
    before: 'git add -A && git commit -m "feat(x): …" && git push -u origin HEAD',
    after: 'gitb commit ai fast push',
  },
  {
    task: 'Sync your branch with main',
    before: 'git fetch && git rebase origin/main && git push --force-with-lease',
    after: 'gitb sync push',
  },
  {
    task: 'Save WIP across machines',
    before: 'git stash -u && git push origin "HEAD:wip/$(git symbolic-ref --short HEAD)"',
    after: 'gitb wip up',
  },
  {
    task: 'Undo last commit (keep changes)',
    before: 'git reset --soft HEAD~1',
    after: 'gitb undo',
  },
  {
    task: 'Tidy a messy branch',
    before: 'git rebase -i HEAD~N   # then fold by hand',
    after: 'gitb squash',
  },
];
---
<section class="section before-after">
  <div class="container">
    <header class="section-title">
      <small>Before & after</small>
      <h2>Type what you want. Skip the rest.</h2>
      <p>
        Every gitbasher command has a short alias too —
        <code>gitb c</code> is <code>gitb commit</code>,
        <code>gitb p</code> is <code>gitb push</code>.
      </p>
    </header>

    <div class="ba-table" role="table" aria-label="Comparison of plain git versus gitbasher commands">
      <div class="ba-head" role="row">
        <div role="columnheader">Task</div>
        <div role="columnheader">Plain <code>git</code></div>
        <div role="columnheader">With <code>gitb</code></div>
      </div>
      {rows.map((r) => (
        <div class="ba-row" role="row">
          <div class="ba-task" role="cell">{r.task}</div>
          <div class="ba-before" role="cell"><code>{r.before}</code></div>
          <div class="ba-after" role="cell"><code>{r.after}</code></div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .ba-table {
    background: var(--bg-elev);
    border: 1px solid var(--border-soft);
    border-radius: var(--radius-lg);
    overflow: hidden;
  }

  .ba-head,
  .ba-row {
    display: grid;
    grid-template-columns: 1.3fr 2fr 1.4fr;
    gap: 1rem;
    padding: 1rem 1.2rem;
  }

  .ba-head {
    background: var(--bg-elev-2);
    color: var(--fg-muted);
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    font-weight: 600;
    border-bottom: 1px solid var(--border-soft);
  }

  .ba-row {
    border-bottom: 1px solid var(--border-soft);
    align-items: center;
  }

  .ba-row:last-child {
    border-bottom: 0;
  }

  .ba-task {
    font-weight: 600;
    color: var(--fg);
  }

  .ba-before code {
    color: var(--fg-muted);
    background: transparent;
    border: 0;
    font-size: 0.85rem;
    padding: 0;
    word-break: break-word;
  }

  .ba-after code {
    color: var(--green);
    background: var(--bg-elev-2);
    border: 1px solid var(--border-soft);
    padding: 0.2em 0.5em;
    font-size: 0.9rem;
  }

  @media (max-width: 820px) {
    .ba-head {
      display: none;
    }

    .ba-row {
      grid-template-columns: 1fr;
      gap: 0.5rem;
      padding: 1rem 1.1rem;
    }

    .ba-task {
      font-size: 0.95rem;
    }

    .ba-before::before {
      content: 'Before';
      display: block;
      font-size: 0.7rem;
      text-transform: uppercase;
      letter-spacing: 0.14em;
      color: var(--fg-subtle);
      margin-bottom: 0.2rem;
    }

    .ba-after::before {
      content: 'After';
      display: block;
      font-size: 0.7rem;
      text-transform: uppercase;
      letter-spacing: 0.14em;
      color: var(--green);
      margin-bottom: 0.2rem;
    }
  }
</style>
