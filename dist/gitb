        ;;
    esac
    echo "$hook_content" > "$hook_file"
    chmod +x "$hook_file"
    echo -e "${GREEN}Created executable hook: $hook_type${ENDCOLOR}"
    echo -e "${YELLOW}Hook file: $hook_file${ENDCOLOR}"
