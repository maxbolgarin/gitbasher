        echo -e "Restore or delete it first: ${YELLOW}gitb wip down branch${ENDCOLOR}"
        exit 1
    fi
    echo -e "${YELLOW}Changes to save:${ENDCOLOR}"
    git_status
    echo
    local original_branch="$current_branch"
    local wip_branch
    wip_branch="$(wip_remote_branch)"
