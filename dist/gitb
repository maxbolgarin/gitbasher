function escape {
    string="$1"
    sub="$2"
    escaped="\\$sub"
    echo "${string//${sub}/${escaped}}"
}
function check_code {
    if [ "$1" != 0 ]; then
        echo
        echo
        echo -e "${RED}Error during $3!${ENDCOLOR}"
        echo -e "$2"
        if [ -n "$git_add" ]; then
            git restore --staged "$git_add"
        fi
        exit $1
    fi
}
function yes_no_choice {
    while true; do
        read -n 1 -s choice
        if is_yes "$choice"; then
            if [ -n "$1" ]; then
                echo -e "${YELLOW}$1${ENDCOLOR}"
                if [ -z "$2" ]; then
                    echo
                fi
            fi
            return
        fi
        if is_no "$choice"; then
            exit
        fi
    done
}
function choose {
    values=("$@")
    number_of_values=${#values[@]}
    while true; do
        if [ "$number_of_values" -gt 9 ]; then
            read -p "$read_prefix" -e -n 2 choice
        else
            read -p "$read_prefix" -n 1 -s choice
        fi
        if [ "$choice" == "0" ] || [ "$choice" == "00" ]; then
            if [ -n "$git_add" ]; then
                git restore --staged "$git_add"
            fi
            if [ "$number_of_values" -le 9 ]; then
                printf "%s" "$choice"
            fi
            exit
        fi
        re='^[0-9=]+$'
        if ! [[ $choice =~ $re ]]; then
            if [ -n "$git_add" ]; then
                git restore --staged "$git_add"
            fi
            exit
        fi
        if [ "$choice" == "=" ] || [ "$choice" == "==" ]; then
            pressed_alt="true"
            break
        fi
        index=$(($choice-1))
        choice_result=${values[index]}
        if [ -n "$choice_result" ]; then
            if [ "$number_of_values" -le 9 ]; then
                printf "%s" "$choice"
            fi
            break
        else
            if [ "$number_of_values" -gt 9 ]; then
                if [ -n "$git_add" ]; then
                    git restore --staged "$git_add"
                fi
                exit
            fi
        fi
    done
}
function git_status {
    status_output=$(git status --short)
    status_output=$(echo "$status_output" | sed "s/^ D/${RED_ES}\tDeleted: ${ENDCOLOR_ES}/")
    status_output=$(echo "$status_output" | sed "s/^D /${GREEN_ES}Staged\t${RED_ES}Deleted: ${ENDCOLOR_ES}/")
