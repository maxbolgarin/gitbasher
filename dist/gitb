#
#
protected_branch=\"main\"
current_branch=\$(git branch --show-current)
remote=\"\$1\"
url=\"\$2\"
echo \"Running pre-push checks...\"
if [ \"\$current_branch\" = \"\$protected_branch\" ]; then
    echo \"❌ Error: Direct push to '\$protected_branch' branch is not allowed\"
