---
const methods = [
  {
    id: 'curl',
    label: 'curl',
    note: 'Recommended. Drops gitb into ~/.local/bin — no sudo. Verifies SHA-256.',
    cmd: 'curl -fsSL https://raw.githubusercontent.com/maxbolgarin/gitbasher/main/install.sh | bash',
  },
  {
    id: 'npm',
    label: 'npm',
    note: 'Easy to remember if Node is already on your machine.',
    cmd: 'npm install -g gitbasher',
  },
  {
    id: 'sudo',
    label: 'system-wide',
    note: 'Install to /usr/local/bin for all users.',
    cmd: 'curl -fsSL https://raw.githubusercontent.com/maxbolgarin/gitbasher/main/install.sh | bash -s -- --sudo',
  },
  {
    id: 'pin',
    label: 'pin a version',
    note: 'Useful for CI or locked environments.',
    cmd: 'GITB_VERSION=v4.0.0 curl -fsSL https://raw.githubusercontent.com/maxbolgarin/gitbasher/main/install.sh | bash',
  },
  {
    id: 'custom',
    label: 'custom directory',
    note: 'Drop gitb in any directory on $PATH.',
    cmd: 'GITB_DIR=/opt/bin curl -fsSL https://raw.githubusercontent.com/maxbolgarin/gitbasher/main/install.sh | bash',
  },
];
---
<section id="install" class="section install">
  <div class="container">
    <header class="section-title">
      <small>Install</small>
      <h2>Install in 10 seconds.</h2>
      <p>
        Pick the method that fits. Once installed, run <code>gitb update</code>
        any time to self-update from the latest GitHub release.
      </p>
    </header>

    <div class="install-tabs" data-tabs>
      <div class="tab-buttons" role="tablist" aria-label="Install methods">
        {methods.map((m, i) => (
          <button
            type="button"
            role="tab"
            id={`tab-${m.id}`}
            aria-controls={`panel-${m.id}`}
            aria-selected={i === 0 ? 'true' : 'false'}
            tabindex={i === 0 ? 0 : -1}
            data-tab-btn={m.id}
            class:list={['tab-btn', i === 0 && 'is-active']}
          >
            {m.label}
          </button>
        ))}
      </div>

      {methods.map((m, i) => (
        <div
          role="tabpanel"
          id={`panel-${m.id}`}
          aria-labelledby={`tab-${m.id}`}
          data-tab-panel={m.id}
          class:list={['tab-panel', i === 0 && 'is-active']}
          hidden={i !== 0}
        >
          <p class="method-note">{m.note}</p>
          <div class="cmd-row">
            <pre><code>{m.cmd}</code></pre>
            <button type="button" class="btn copy-btn" data-copy={m.cmd}>
              <span class="copy-label">Copy</span>
              <span class="copied-label" aria-hidden="true">Copied!</span>
            </button>
          </div>
        </div>
      ))}
    </div>

    <p class="install-foot">
      Need to upgrade? <code>gitb update</code>.
      Need to remove it? <code>gitb uninstall</code>.
      See the
      <a href="https://github.com/maxbolgarin/gitbasher#install-in-10-seconds" rel="noopener">
        full install guide on GitHub
      </a>.
    </p>
  </div>
</section>

<script>
  const tabs = document.querySelectorAll<HTMLElement>('[data-tabs]');
  tabs.forEach((root) => {
    const buttons = root.querySelectorAll<HTMLButtonElement>('[data-tab-btn]');
    const panels = root.querySelectorAll<HTMLElement>('[data-tab-panel]');

    const activate = (id: string) => {
      buttons.forEach((b) => {
        const active = b.dataset.tabBtn === id;
        b.classList.toggle('is-active', active);
        b.setAttribute('aria-selected', active ? 'true' : 'false');
        b.tabIndex = active ? 0 : -1;
      });
      panels.forEach((p) => {
        const active = p.dataset.tabPanel === id;
        p.classList.toggle('is-active', active);
        p.hidden = !active;
      });
    };

    buttons.forEach((btn, idx) => {
      btn.addEventListener('click', () => activate(btn.dataset.tabBtn ?? ''));
      btn.addEventListener('keydown', (e) => {
        if (e.key === 'ArrowRight' || e.key === 'ArrowLeft') {
          e.preventDefault();
          const next =
            e.key === 'ArrowRight'
              ? (idx + 1) % buttons.length
              : (idx - 1 + buttons.length) % buttons.length;
          const target = buttons[next];
          if (target) {
            target.focus();
            activate(target.dataset.tabBtn ?? '');
          }
        }
      });
    });
  });

  // Copy buttons (scoped here too so this section is self-contained if reused)
  const copyButtons = document.querySelectorAll<HTMLButtonElement>('.install .copy-btn');
  copyButtons.forEach((btn) => {
    btn.addEventListener('click', async () => {
      const text = btn.dataset.copy ?? '';
      try {
        await navigator.clipboard.writeText(text);
      } catch {
        const ta = document.createElement('textarea');
        ta.value = text;
        document.body.appendChild(ta);
        ta.select();
        document.execCommand('copy');
        ta.remove();
      }
      btn.classList.add('is-copied');
      setTimeout(() => btn.classList.remove('is-copied'), 1500);
    });
  });
</script>

<style>
  .install-tabs {
    background: var(--bg-elev);
    border: 1px solid var(--border-soft);
    border-radius: var(--radius-lg);
    overflow: hidden;
    max-width: 880px;
    margin: 0 auto;
  }

  .tab-buttons {
    display: flex;
    overflow-x: auto;
    background: var(--bg-elev-2);
    border-bottom: 1px solid var(--border-soft);
  }

  .tab-btn {
    background: transparent;
    border: 0;
    color: var(--fg-muted);
    padding: 0.85rem 1.1rem;
    font-size: 0.9rem;
    font-weight: 600;
    cursor: pointer;
    border-bottom: 2px solid transparent;
    white-space: nowrap;
  }

  .tab-btn:hover {
    color: var(--fg);
  }

  .tab-btn.is-active {
    color: var(--green);
    border-bottom-color: var(--green);
  }

  .tab-panel {
    padding: 1.4rem;
  }

  .method-note {
    color: var(--fg-muted);
    font-size: 0.95rem;
    margin: 0 0 0.9rem;
  }

  .cmd-row {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 0.6rem;
    align-items: center;
  }

  .cmd-row pre {
    margin: 0;
    font-size: 0.85rem;
  }

  .cmd-row .copy-btn {
    align-self: stretch;
    position: relative;
  }

  .copy-btn .copied-label {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--green);
    opacity: 0;
  }

  .copy-btn.is-copied .copy-label {
    opacity: 0;
  }
  .copy-btn.is-copied .copied-label {
    opacity: 1;
  }

  .install-foot {
    text-align: center;
    color: var(--fg-muted);
    margin-top: 1.4rem;
    font-size: 0.92rem;
  }

  @media (max-width: 580px) {
    .cmd-row {
      grid-template-columns: 1fr;
    }
  }
</style>
